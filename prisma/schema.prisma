generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum ParseStatus {
  SUCCESS
  PARTIAL
  FAILED
}

enum FlagType {
  WARNING
  ERROR
  INFO
}

enum StorageProvider {
  LOCAL
  S3
  GCS
  AZURE
}

enum UserRole {
  ADMIN
  TECHNICIAN
  CLINICIAN
  VIEWER
}

enum AuditAction {
  CREATED
  MODIFIED
  VALIDATED
  ACCESSED
  DELETED
}

enum AuditStatus {
  SUCCESS
  FAILED
}

model LabReport {
  id                String            @id @default(cuid())

  analyzerId        String
  analyzer          Analyzer          @relation(fields: [analyzerId], references: [id])

  sampleId          String            @unique

  patientGender     Gender?

  analyzerModel     String
  softwareVersion   String?
  serialNumber      String?

  testTimestamp     DateTime

  sourceFormat      String
  parserVersion     String
  parseStatus       ParseStatus
  parseErrors       Json?

  results           TestResult[]
  imageArtifacts    ImageArtifact[]
  qualityFlags      QualityFlag[]
  auditLogs         AuditLog[]

  isEncrypted       Boolean           @default(true)
  encryptionKeyId   String?
  encryptionKey     EncryptionKey?    @relation(fields: [encryptionKeyId], references: [id])

  hipaaCompliant    Boolean           @default(true)
  dataRetentionDays Int               @default(2555)

  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  deletedAt         DateTime?

  @@index([sampleId])
  @@index([testTimestamp])
  @@index([deletedAt])
  @@index([analyzerId])
}

model TestResult {
  id                String            @id @default(cuid())

  reportId          String
  report            LabReport         @relation(fields: [reportId], references: [id], onDelete: Cascade)

  testCode          String

  value             Decimal?          @db.Decimal(10, 3)
  stringValue       String?

  unit              String?

  abnormalFlag      String?

  referenceMin      Decimal?          @db.Decimal(10, 3)
  referenceMax      Decimal?          @db.Decimal(10, 3)

  criticalMin       Decimal?          @db.Decimal(10, 3)
  criticalMax       Decimal?          @db.Decimal(10, 3)

  isAbnormal        Boolean           @default(false)
  isCritical        Boolean           @default(false)

  qualityScore      Float?
  comments          String?

  isValidated       Boolean           @default(false)
  validatedBy       String?
  validationNotes   String?

  timestamp         DateTime

  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@unique([reportId, testCode])
  @@index([testCode])
  @@index([isAbnormal])
  @@index([isCritical])
}

model ImageArtifact {
  id                String            @id @default(cuid())

  reportId          String
  report            LabReport         @relation(fields: [reportId], references: [id], onDelete: Cascade)

  testCode          String

  fileType          String
  fileName          String
  filePath          String

  fileSize          Int?
  fileHash          String?

  width             Int?
  height            Int?

  quality           String?

  storageProvider   StorageProvider

  isProcessed       Boolean           @default(false)

  processingErrors  Json?

  timestamp         DateTime

  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([reportId])
  @@index([testCode])
}

model QualityFlag {
  id                String            @id @default(cuid())

  reportId          String
  report            LabReport         @relation(fields: [reportId], references: [id], onDelete: Cascade)

  flagType          FlagType

  code              String
  message           String

  severity          Int

  testCode          String?

  metadata          Json?

  isResolved        Boolean           @default(false)

  resolvedAt        DateTime?
  resolvedBy        String?
  resolutionNote    String?

  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([flagType])
  @@index([isResolved])
}

model AuditLog {
  id                String            @id @default(cuid())

  reportId          String
  report            LabReport         @relation(fields: [reportId], references: [id], onDelete: Cascade)

  action            AuditAction

  userId            String?
  user              User?             @relation(fields: [userId], references: [id])

  ipAddress         String?
  userAgent         String?

  changedFields     Json?
  oldValues         Json?
  newValues         Json?

  reason            String?

  status            AuditStatus

  errorMessage      String?

  createdAt         DateTime          @default(now())

  @@index([action])
  @@index([createdAt])
}

model ReferenceRange {
  id                String            @id @default(cuid())

  analyzerId        String
  analyzer          Analyzer          @relation(fields: [analyzerId], references: [id], onDelete: Cascade)

  testCode          String

  ageMin            Int?
  ageMax            Int?

  gender            Gender?

  referenceMin      Decimal?          @db.Decimal(10, 3)
  referenceMax      Decimal?          @db.Decimal(10, 3)

  criticalMin       Decimal?          @db.Decimal(10, 3)
  criticalMax       Decimal?          @db.Decimal(10, 3)

  unit              String

  source            String

  lastUpdated       DateTime

  notes             String?

  isActive          Boolean           @default(true)

  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([testCode])
  @@index([isActive])
}

model Analyzer {
  id                String            @id @default(cuid())

  model             String            @unique

  manufacturer      String

  softwareVersions  Json

  format            String

  delimiter         String            @default("|")
  fieldDelimiter    String            @default("^")

  supportedTests    Json

  defaultUnit       String?

  referenceRanges   ReferenceRange[]

  reports           LabReport[]

  isActive          Boolean           @default(true)

  notes             String?

  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([manufacturer])
}

model User {
  id                String            @id @default(cuid())

  email             String            @unique
  name              String

  role              UserRole

  permissions       Json

  allowedAnalyzers  Json?

  passwordHash      String

  mfaEnabled        Boolean           @default(false)
  mfaSecret         String?

  lastLogin         DateTime?

  isActive          Boolean           @default(true)

  auditLogs         AuditLog[]

  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  deletedAt         DateTime?

  @@index([role])
  @@index([isActive])
}

model EncryptionKey {
  id                String            @id @default(cuid())

  version           Int               @unique

  algorithm         String

  publicKey         String

  isActive          Boolean           @default(true)

  rotatedAt         DateTime?

  reports           LabReport[]

  createdAt         DateTime          @default(now())
}